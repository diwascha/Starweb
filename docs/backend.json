
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the application.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "username": {
          "type": "string",
          "description": "The user's chosen username."
        },
        "permissions": {
          "type": "object",
          "description": "A map of module to action permissions."
        }
      },
      "required": ["id", "username"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores additional information about a user.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user this profile belongs to."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "URL of the user's profile picture."
        }
      },
      "required": ["userId"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A daily operational expense related to a vehicle.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "vehicleId": { "type": "string" },
        "expenseType": { "type": "string", "enum": ["Advance", "Maintenance", "Purchase", "Loan Repayment", "Membership Renewal"] },
        "amount": { "type": "number" },
        "paymentMode": { "type": "string", "enum": ["Cash", "Bank"] },
        "partyId": { "type": "string" },
        "accountId": { "type": "string" },
        "remarks": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "vehicleId", "expenseType", "amount", "paymentMode", "createdBy"]
    },
    "Cheque": {
      "title": "Cheque Voucher",
      "description": "Post-dated or issued cheque record for payments.",
      "type": "object",
      "properties": {
        "voucherNo": { "type": "string" },
        "paymentDate": { "type": "string", "format": "date-time" },
        "partyName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Due", "Paid", "Canceled", "Partially Paid"] }
      },
      "required": ["voucherNo", "paymentDate", "partyName", "amount"]
    },
    "FileRecord": {
      "title": "File Record",
      "description": "Metadata for files stored in Firebase Storage.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "size": { "type": "number" },
        "type": { "type": "string" },
        "path": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "category": { "type": "string", "enum": ["General", "HR", "Fleet", "Finance", "CRM"] }
      },
      "required": ["name", "url", "path", "uploadedBy", "uploadedAt"]
    },
    "SystemLog": {
      "title": "System Log",
      "description": "Captures application crashes and events for debugging.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "level": { "type": "string", "enum": ["error", "warn", "info"] },
        "module": { "type": "string" },
        "message": { "type": "string" },
        "stack": { "type": "string" },
        "username": { "type": "string" },
        "userId": { "type": "string" },
        "context": { "type": "object" }
      },
      "required": ["timestamp", "level", "message"]
    },
    "HrShift": {
      "title": "HR Shift",
      "description": "Definition of standard working hours and shift timings.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "onDuty": { "type": "string" },
        "offDuty": { "type": "string" },
        "breakStart": { "type": "string" },
        "breakEnd": { "type": "string" },
        "isDefault": { "type": "boolean" }
      },
      "required": ["name", "onDuty", "offDuty"]
    },
    "PublicHoliday": {
      "title": "Public Holiday",
      "description": "A calendar date marked as a non-working day for all employees.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "isRecurring": { "type": "boolean" }
      },
      "required": ["name", "date"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores public profiles for users."
    },
    "/cheques/{chequeId}": {
      "schema": { "$ref": "#/entities/Cheque" },
      "description": "Registry of issued and post-dated cheques."
    },
    "/expenses/{expenseId}": {
      "schema": { "$ref": "#/entities/Expense" },
      "description": "Stores daily operational expenses for fleet management."
    },
    "/files/{fileId}": {
      "schema": { "$ref": "#/entities/FileRecord" },
      "description": "Index of files for the document management system."
    },
    "/logs/{logId}": {
      "schema": { "$ref": "#/entities/SystemLog" },
      "description": "Historical audit log of system exceptions and events."
    },
    "/hr_shifts/{shiftId}": {
        "schema": { "$ref": "#/entities/HrShift" },
        "description": "Configuration for employee shifts."
    },
    "/public_holidays/{holidayId}": {
        "schema": { "$ref": "#/entities/PublicHoliday" },
        "description": "Registry of company-wide public holidays."
    }
  }
}
