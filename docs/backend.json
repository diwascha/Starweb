
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the application with RBAC permissions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "isAdmin": { "type": "boolean" },
        "isApproved": { "type": "boolean" },
        "permissions": { "type": "object" },
        "passwordLastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username"]
    },
    "PurchaseOrder": {
      "title": "Purchase Order",
      "description": "Procurement document for raw materials.",
      "type": "object",
      "properties": {
        "poNumber": { "type": "string" },
        "poDate": { "type": "string", "format": "date-time" },
        "companyName": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Ordered", "Amended", "Delivered", "Canceled"] },
        "items": { "type": "array" }
      },
      "required": ["poNumber", "poDate", "companyName", "items"]
    },
    "Cheque": {
      "title": "Cheque Voucher",
      "description": "PDC or issued cheque record for payments.",
      "type": "object",
      "properties": {
        "voucherNo": { "type": "string" },
        "payeeName": { "type": "string" },
        "amount": { "type": "number" },
        "splits": { "type": "array" },
        "status": { "type": "string" }
      },
      "required": ["voucherNo", "payeeName", "amount"]
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "General ledger entry for income or expense.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["Purchase", "Sales", "Payment", "Receipt"] },
        "amount": { "type": "number" },
        "billingType": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["date", "type", "amount"]
    },
    "Employee": {
      "title": "Employee Profile",
      "description": "Personnel master record.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string" },
        "wageBasis": { "type": "string" },
        "wageAmount": { "type": "number" }
      },
      "required": ["name", "status", "wageBasis", "wageAmount"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/system_users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Master user directory with security flags."
    },
    "/purchaseOrders/{id}": {
      "schema": { "$ref": "#/entities/PurchaseOrder" },
      "description": "Procurement registry."
    },
    "/cheques/{id}": {
      "schema": { "$ref": "#/entities/Cheque" },
      "description": "PDC and voucher registry."
    },
    "/transactions/{id}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Unified financial ledger."
    },
    "/expenses/{id}": {
      "schema": { "$ref": "#/entities/Expense" },
      "description": "Direct operational expense tracking."
    },
    "/employees/{id}": {
      "schema": { "$ref": "#/entities/Employee" },
      "description": "Workforce master data."
    },
    "/attendance/{id}": {
      "schema": { "type": "object" },
      "description": "Processed labor metrics."
    },
    "/payroll/{id}": {
      "schema": { "type": "object" },
      "description": "Monthly financial settlements for staff."
    },
    "/settings/{id}": {
      "schema": { "type": "object" },
      "description": "System-wide configuration and branding."
    }
  }
}
