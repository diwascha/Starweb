rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the currently signed-in user an admin?
    // Uses exists() to prevent evaluation errors if the profile doesn't exist yet.
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/system_users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/system_users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Helper: is the currently signed-in user an approved business user?
    function isApproved() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/system_users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/system_users/$(request.auth.uid)).data.isApproved == true;
    }

    // Username -> email lookup. Must be publicly readable so the login
    // page can resolve "administrator" (or any username) to an email
    // BEFORE the person is signed in. Only admins can create/change these.
    match /usernames/{username} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profiles and system access control.
    match /system_users/{userId} {
      allow read: if request.auth != null;

      // A user may update their own profile fields, but never touch isAdmin or isApproved.
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.isAdmin == resource.data.isAdmin
        && request.resource.data.isApproved == resource.data.isApproved;

      // Admins have full management control.
      allow create, delete, update: if isAdmin();
    }

    // Settings collection.
    // Branding is public for the login screen; other configurations require auth.
    match /settings/{settingId} {
      allow read: if settingId in ['companyProfile', 'appBranding', 'fleetCompanyProfile'] || request.auth != null;
      allow write: if isAdmin();
    }

    // Explicitly allow core application data collections for approved users.
    // This provides the most reliable listing behavior for onSnapshot listeners.
    match /estimatedInvoices/{id} { allow read, write: if isApproved(); }
    match /cheques/{id} { allow read, write: if isApproved(); }
    match /tdsCalculations/{id} { allow read, write: if isApproved(); }
    match /reports/{id} { allow read, write: if isApproved(); }
    match /products/{id} { allow read, write: if isApproved(); }
    match /purchaseOrders/{id} { allow read, write: if isApproved(); }
    match /rawMaterials/{id} { allow read, write: if isApproved(); }
    match /employees/{id} { allow read, write: if isApproved(); }
    match /attendance/{id} { allow read, write: if isApproved(); }
    match /payroll/{id} { allow read, write: if isApproved(); }
    match /vehicles/{id} { allow read, write: if isApproved(); }
    match /drivers/{id} { allow read, write: if isApproved(); }
    match /policies/{id} { allow read, write: if isApproved(); }
    match /transactions/{id} { allow read, write: if isApproved(); }
    match /parties/{id} { allow read, write: if isApproved(); }
    match /accounts/{id} { allow read, write: if isApproved(); }
    match /uom/{id} { allow read, write: if isApproved(); }
    match /destinations/{id} { allow read, write: if isApproved(); }
    match /trips/{id} { allow read, write: if isApproved(); }
    match /notes/{id} { allow read, write: if isApproved(); }
    match /pageVisits/{id} { allow read, write: if isApproved(); }
    match /logs/{id} { allow read, write: if isApproved(); }
    match /files/{id} { allow read, write: if isApproved(); }
    match /rentalProperties/{id} { allow read, write: if isApproved(); }
    match /rentalUnits/{id} { allow read, write: if isApproved(); }
    match /rentalAgreements/{id} { allow read, write: if isApproved(); }
    match /rentalBills/{id} { allow read, write: if isApproved(); }

    // Recursive fallback for nested structures and subcollections.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}