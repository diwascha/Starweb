rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the currently signed-in user an admin?
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/system_users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/system_users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Username -> email lookup. Must be publicly readable so the login
    // page can resolve "administrator" (or any username) to an email
    // BEFORE the person is signed in. Only admins can create/change these.
    match /usernames/{username} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profiles and system user management.
    match /system_users/{userId} {
      allow read: if request.auth != null;

      // A user may update their own document, but never touch isAdmin
      // or isApproved themselves.
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.isAdmin == resource.data.isAdmin
        && request.resource.data.isApproved == resource.data.isApproved;

      // Admins have full control over user documents.
      allow read, write: if isAdmin();
    }

    // Settings collection.
    // Branding and profile info must be publicly readable for the login screen.
    match /settings/{settingId} {
      allow read: if settingId in ['companyProfile', 'appBranding', 'fleetCompanyProfile'] || request.auth != null;
      allow write: if isAdmin();
    }

    // Main application data (Reports, Fleet, HR, Finance, pageVisits, etc.)
    // Any authenticated user can read/write to these collections. 
    // Finer-grained module permissions are handled in the UI via hasPermission().
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}