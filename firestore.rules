rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Security Helpers ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/system_users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/system_users/$(request.auth.uid)) && 
             getUserData().isAdmin == true;
    }

    function isApproved() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/system_users/$(request.auth.uid)) && 
             getUserData().isApproved == true;
    }

    // --- Identity & Settings ---

    match /settings/{settingId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /system_users/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId;
      allow create: if true; // Allow initial profile creation during registration
      allow delete: if isAdmin();
      allow update: if isAdmin() || (
        request.auth.uid == userId &&
        request.resource.data.isApproved == resource.data.isApproved &&
        request.resource.data.isAdmin == resource.data.isAdmin
      );
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // --- Application Data ---

    match /{document=**} {
      // General rule: Approved users can read/write data. 
      // Individual services should refine this if granular multi-tenant isolation is needed.
      allow read, write: if isApproved();
    }
  }
}