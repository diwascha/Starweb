
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Security Helpers ---

    function isAuthenticated() {
      return request.auth != null;
    }

    // Centrally managed approval check. Defaults to true if field is missing for legacy support,
    // but requires a valid user document in system_users.
    function isApproved() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/system_users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/system_users/$(request.auth.uid)).data.get('isApproved', true) == true;
    }

    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/system_users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/system_users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    // --- Semi-Public Configurations ---

    // Branding and basic company info must be readable for the app to boot correctly
    match /settings/companyProfile { allow read: if true; }
    match /settings/fleetCompanyProfile { allow read: if true; }
    match /settings/appBranding { allow read: if true; }
    match /settings/ownership_categories { allow read: if true; }

    match /settings/{settingId} {
      allow read: if isAuthenticated(); 
      allow write: if isAdmin();
    }

    // --- Identity & Access ---

    match /system_users/{userId} {
      // Allow read for authenticated users to resolve identities.
      // Allow create for signup flow.
      allow read: if isAuthenticated(); 
      allow create: if true; 
      
      // An admin cannot demote themselves or disable their own account to prevent lockout.
      // Users can update their own non-security fields.
      allow update: if (isAdmin() && request.auth.uid != userId) || 
                       (isAuthenticated() && request.auth.uid == userId && 
                        request.resource.data.get('isApproved', true) == resource.data.get('isApproved', true) &&
                        request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false));
                        
      allow delete: if isAdmin() && userId != request.auth.uid && 
                       resource.data.get('isAdmin', false) != true;
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }
    
    match /logs/{logId} {
      allow create: if true; // Always allow logging to capture errors
      allow read, delete: if isAdmin();
    }

    // --- Unified Application Data Rules ---

    // This catch-all ensures all documented modules follow the central isApproved requirement.
    match /{collectionName}/{docId} {
      allow read, write: if isApproved();
      
      // Allow access to subcollections (like item history or amendments)
      match /{allPaths=**} {
        allow read, write: if isApproved();
      }
    }
  }
}
