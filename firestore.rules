rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the currently signed-in user an admin?
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/system_users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Username -> email lookup. Must be publicly readable so the login
    // page can resolve "administrator" (or any username) to an email
    // BEFORE the person is signed in. Only admins can create/change these,
    // since only admins create accounts in this app.
    match /usernames/{username} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profiles.
    match /system_users/{userId} {
      allow read: if request.auth != null;

      // A user may update their own document, but never touch isAdmin
      // or isApproved themselves.
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.isAdmin == resource.data.isAdmin
        && request.resource.data.isApproved == resource.data.isApproved;

      // Only an admin can create new user docs, delete user docs,
      // or change isAdmin / isApproved on anyone (including themselves
      // being demoted by another admin, or approving/promoting others).
      allow create, delete: if isAdmin();
      allow update: if isAdmin();
    }

    // Everything else in the app (finance, hr, crm, fleet, rental,
    // reports, purchaseOrders, notes, settings, etc.) — any signed-in,
    // approved user can read/write. Your app's own hasPermission() checks
    // in the UI handle the finer-grained module permissions; this rule
    // is the baseline "must be logged in" gate.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}