rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the currently signed-in user authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: get current user data
    function getUserData() {
      return get(/databases/$(database)/documents/system_users/$(request.auth.uid)).data;
    }

    // Helper: is the user approved by an administrator?
    function isApproved() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/system_users/$(request.auth.uid)) && 
        getUserData().isApproved == true;
    }

    // Helper: is the user a system administrator?
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/system_users/$(request.auth.uid)) && 
        getUserData().isAdmin == true;
    }

    // Branding and profile settings (Publicly readable for login screen)
    match /settings/{settingId} {
      allow read: if settingId in ['companyProfile', 'appBranding', 'fleetCompanyProfile'] || isApproved();
      allow write: if isAdmin();
    }

    // User directory and security mappings
    match /system_users/{userId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (request.auth.uid == userId && request.resource.data.isApproved == resource.data.isApproved);
    }

    match /usernames/{username} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Application Data Collections
    // Pattern: Read allowed for all authenticated, Write restricted to approved
    match /{collection}/{id} {
      allow read: if isAuthenticated();
      allow write: if isApproved();
    }

    // Catch-all recursive safety
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isApproved();
    }
  }
}