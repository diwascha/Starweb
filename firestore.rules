rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Security Helpers ---
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user document exists and is approved
    function isApproved() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/system_users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/system_users/$(request.auth.uid)).data.isApproved == true;
    }

    // Check if user is a system administrator
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/system_users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/system_users/$(request.auth.uid)).data.isAdmin == true;
    }

    // --- Identity & Settings (Critical Path) ---

    // Branding and profile settings (Publicly readable for login/loading screens)
    match /settings/{settingId} {
      allow read: if true; 
      allow write: if isApproved();
    }

    // User directory and security mappings
    match /system_users/{userId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (request.auth.uid == userId && request.resource.data.isApproved == resource.data.isApproved);
    }

    // Username uniqueness registry
    match /usernames/{username} {
      allow read: if true;
      allow write: if isAdmin() || isAuthenticated();
    }

    // --- Application Data Modules ---

    // Explicitly allow core collections for all authenticated/approved users
    match /{collectionId}/{docId} {
      allow read: if isAuthenticated();
      allow write: if isApproved();

      // Support for sub-collections (e.g., employee documents or logs)
      match /{subCollection}/{subDocId} {
        allow read: if isAuthenticated();
        allow write: if isApproved();
      }
    }

    // --- Global Resiliency Gate ---
    
    // Fallback recursive match ensures that nested queries in complex logic 
    // (like Payroll or Fleet Ledger) don't trigger permission denied errors.
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isApproved();
    }
  }
}