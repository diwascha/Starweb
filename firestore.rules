rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Security Helpers ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isApproved() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/system_users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/system_users/$(request.auth.uid)).data.isApproved == true;
    }

    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/system_users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/system_users/$(request.auth.uid)).data.isAdmin == true;
    }

    // --- Identity & Settings ---

    // Allow public read for branding and setup so login works for all users
    match /settings/companyProfile { allow read: if true; }
    match /settings/fleetCompanyProfile { allow read: if true; }
    match /settings/appBranding { allow read: if true; }
    match /settings/ownership_categories { allow read: if true; }

    match /settings/{settingId} {
      allow read: if isAuthenticated(); 
      allow write: if isAdmin();
    }

    match /system_users/{userId} {
      // Allow read for self or admins. Also allow public read for login resolution.
      allow read: if true; 
      allow create: if true; 
      
      // CRITICAL: Prevent deletion of any administrator via the app
      allow delete: if isAdmin() && (resource == null || resource.data.isAdmin != true);
      
      allow update: if (isAdmin() && (
        // An admin cannot demote themselves or disable their own account to prevent lockout
        request.auth.uid != userId || (
            request.resource.data.isAdmin == true && 
            request.resource.data.isApproved == true
        )
      )) || (
        isAuthenticated() && request.auth.uid == userId &&
        request.resource.data.get('isApproved', true) == resource.data.get('isApproved', true) &&
        request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false)
      );
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }
    
    // --- Logging ---
    match /logs/{logId} {
      allow create: if true; // Always allow logging errors
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- Application Data ---

    match /{collectionName}/{docId} {
      // Approved users can access all application data
      allow read, write: if isApproved();
    }

    match /{document=**} {
      // Catch-all safety for nested subcollections
      allow read, write: if isApproved();
    }
  }
}